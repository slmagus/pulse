# ── Anthropic (default provider) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── vLLM local model (set LLM_PROVIDER=vllm to use instead of Anthropic) ──────
# LLM_PROVIDER=vllm
# LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct

# Base URL for the vLLM server (default: http://localhost:8000)
# If vLLM runs on the host and the backend runs in Docker, use:
#   LLM_BASE_URL=http://host.docker.internal:8000   (Windows/Mac Docker Desktop)
#   LLM_BASE_URL=http://172.17.0.1:8000             (Linux)
# If vLLM is its own Docker service, use its service name:
#   LLM_BASE_URL=http://vllm:8000
# LLM_BASE_URL=http://localhost:8000
